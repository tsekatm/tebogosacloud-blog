---
interface Props {
  category: string;
}

const { category } = Astro.props;

const categoryColors: Record<string, string> = {
  'AWS & Cloud Architecture': 'bg-orange-500/10 text-orange-400 border-orange-500/20',
  'DevOps & Infrastructure': 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  'GenAI & AI Engineering': 'bg-purple-500/10 text-purple-400 border-purple-500/20',
  'Cloud Security': 'bg-red-500/10 text-red-400 border-red-500/20',
  'Career & Leadership': 'bg-green-500/10 text-green-400 border-green-500/20',
  'Technical Deep Dives': 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
};

const colorClass = categoryColors[category] || 'badge';
---

<span class:list={['inline-block px-2.5 py-0.5 text-xs font-medium rounded-full border', colorClass]}>
  {category}
</span>
