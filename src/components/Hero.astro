---
import Newsletter from './Newsletter.astro';
import SocialLinks from './SocialLinks.astro';
---

<section class="relative overflow-hidden">
  <!-- Subtle gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-black via-brand-dark to-brand-black"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-brand-beige/5 via-transparent to-transparent"></div>

  <div class="relative container-wide py-20 md:py-32">
    <div class="grid md:grid-cols-5 gap-12 items-center">
      <!-- Text Content -->
      <div class="md:col-span-3 space-y-6">
        <p class="text-brand-beige font-medium tracking-wide uppercase text-sm">
          Cloud Architect & Engineering Leader
        </p>

        <h1 class="text-4xl md:text-6xl font-extrabold text-brand-light leading-tight">
          Hi, I'm <span class="text-brand-beige">Tebogo</span>
        </h1>

        <p class="text-lg md:text-xl text-brand-grey leading-relaxed max-w-2xl">
          Cloud architect and engineering leader building scalable platforms on AWS.
          Writing about architecture, DevOps, AI, and the journey to senior technical leadership.
        </p>

        <div class="flex flex-wrap gap-3 pt-2">
          <a
            href="/blog"
            class="inline-flex items-center px-6 py-3 rounded-lg bg-brand-beige text-brand-black font-semibold text-sm hover:bg-brand-cream transition-colors"
          >
            Read the Blog
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/projects"
            class="inline-flex items-center px-6 py-3 rounded-lg border border-brand-border text-brand-cream font-semibold text-sm hover:border-brand-beige/50 hover:text-brand-beige transition-colors"
          >
            View Projects
          </a>
        </div>

        <div class="pt-4">
          <SocialLinks />
        </div>
      </div>

      <!-- Headshot -->
      <div class="md:col-span-2 flex justify-center">
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-brand-beige/20 to-transparent rounded-full blur-2xl"></div>
          <img
            src="/headshot.jpg"
            alt="Tebogo Tseka"
            class="relative w-64 h-64 md:w-80 md:h-80 rounded-full object-cover object-top border-4 border-brand-beige/20 shadow-2xl"
          />
        </div>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="mt-16 pt-12 border-t border-brand-border/30">
      <Newsletter />
    </div>
  </div>
</section>
