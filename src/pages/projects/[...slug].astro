---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}

type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await project.render();
---

<BaseLayout title={project.data.title} description={project.data.description} image={project.data.heroImage}>
  <article class="container-narrow py-16 md:py-24">
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs text-brand-beige font-medium uppercase tracking-wider">{project.data.role}</span>
        <span class="text-xs text-brand-grey">{project.data.year}</span>
      </div>

      <h1 class="text-3xl md:text-5xl font-bold text-brand-light leading-tight mb-4">
        {project.data.title}
      </h1>

      <p class="text-lg text-brand-grey">{project.data.description}</p>

      <div class="flex flex-wrap gap-2 mt-6">
        {project.data.techStack.map((tech) => (
          <span class="badge">{tech}</span>
        ))}
      </div>

      <div class="flex gap-4 mt-6">
        {project.data.liveUrl && (
          <a href={project.data.liveUrl} target="_blank" rel="noopener"
             class="inline-flex items-center px-4 py-2 rounded-lg bg-brand-beige text-brand-black font-semibold text-sm hover:bg-brand-cream transition-colors">
            View Live
          </a>
        )}
        {project.data.repoUrl && (
          <a href={project.data.repoUrl} target="_blank" rel="noopener"
             class="inline-flex items-center px-4 py-2 rounded-lg border border-brand-border text-brand-cream text-sm hover:border-brand-beige/50 transition-colors">
            Source Code
          </a>
        )}
      </div>
    </header>

    {project.data.heroImage && (
      <img src={project.data.heroImage} alt={project.data.title}
           class="w-full rounded-xl mb-12 border border-brand-border" />
    )}

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
